# Copy this file to .env and fill in the keys you have. .env is gitignored, so
# your keys never get committed. You do NOT need any of these to run the tests,
# the offline demo, or a local Ollama model. You need at least one to compare
# premium or hosted open-weight models.
#
# Each key maps to models in models.toml. Enable a model there (enabled = true)
# once its key is set.

# ---------------------------------------------------------------------------
# Recommended: one key for everything.
# OpenRouter is OpenAI-compatible and reaches Claude, Gemini, GPT, Llama, Qwen,
# DeepSeek, and gpt-oss through a single endpoint. Simplest path to comparing
# premium and open models side by side.
OPENROUTER_API_KEY=

# ---------------------------------------------------------------------------
# Direct provider keys (optional, use instead of or alongside OpenRouter).

# OpenAI: GPT-4o and similar. Also serves OpenAI open models where offered.
OPENAI_API_KEY=

# Google Gemini: works through Google's OpenAI-compatible endpoint.
GEMINI_API_KEY=

# Anthropic Claude: needs a dedicated provider (its API is not OpenAI-compatible),
# which is a small planned addition. Until then, reach Claude via OpenRouter.
ANTHROPIC_API_KEY=

# Hugging Face: open models through the HF OpenAI-compatible router.
HF_TOKEN=

# Together: hosted open-weight models (Qwen, DeepSeek, Llama, gpt-oss).
TOGETHER_API_KEY=

# Groq: very fast inference for Llama, Qwen, and gpt-oss. Has a free tier.
GROQ_API_KEY=

# Mistral: Mistral's own OpenAI-compatible endpoint.
MISTRAL_API_KEY=
